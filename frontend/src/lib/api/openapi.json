  "components": {
    "schemas": {
      "Axis": {
        "properties": {
          "score": {
            "type": "number",
            "maximum": 10.0,
            "minimum": 1.0,
            "title": "Score"
          },
          "trend": {
            "type": "string",
            "enum": [
              "improving",
              "stable",
              "declining"
            ],
            "title": "Trend"
          },
          "claim_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Claim Ids"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "score",
          "trend",
          "claim_ids"
        ],
        "title": "Axis"
      },
      "Candidate": {
        "properties": {
          "gh_login": {
            "type": "string",
            "title": "Gh Login"
          },
          "founder_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Founder Name"
          },
          "company": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Company"
          },
          "source": {
            "type": "string",
            "enum": [
              "outbound_detector",
              "inbound_application"
            ],
            "title": "Source"
          },
          "current_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Current Score"
          },
          "score_percentile": {
            "type": "number",
            "title": "Score Percentile"
          },
          "momentum_3mo": {
            "type": "number",
            "title": "Momentum 3Mo"
          },
          "first_detection_month": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "First Detection Month"
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate",
              "screened",
              "memo_ready"
            ],
            "title": "Status"
          },
          "has_memo": {
            "type": "boolean",
            "title": "Has Memo"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "gh_login",
          "founder_name",
          "company",
          "source",
          "current_score",
          "score_percentile",
          "momentum_3mo",
          "first_detection_month",
          "status",
          "has_memo"
        ],
        "title": "Candidate"
      },
      "CandidateDetail": {
        "properties": {
          "candidate": {
            "$ref": "#/components/schemas/Candidate"
          },
          "trajectory": {
            "items": {
              "$ref": "#/components/schemas/TrajectoryPoint"
            },
            "type": "array",
            "title": "Trajectory"
          },
          "recognition": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Recognition"
              },
              {
                "type": "null"
              }
            ]
          },
          "score_components": {
            "items": {
              "$ref": "#/components/schemas/ScoreComponent"
            },
            "type": "array",
            "title": "Score Components"
          },
          "three_axis": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ThreeAxis"
              },
              {
                "type": "null"
              }
            ]
          },
          "memo_available": {
            "type": "boolean",
            "title": "Memo Available"
          },
          "evidence_counts_by_type": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Evidence Counts By Type"
          }
