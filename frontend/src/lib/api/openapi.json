            "title": "Verification Status"
          },
          "contradictions": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Contradictions"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "text",
          "evidence_refs",
          "confidence",
          "verification_status",
          "contradictions"
