            "type": "integer",
            "title": "Total"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "items",
          "total"
        ],
        "title": "CandidatePage"
      },
      "Claim": {
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "title": "Text"
          },
          "evidence_refs": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "Evidence Refs"
          },
          "confidence": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence"
          },
          "verification_status": {
            "type": "string",
            "enum": [
              "verified",
              "single_source",
              "unverified",
              "not_disclosed"
